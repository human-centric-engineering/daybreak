// Framework — Modules domain: module config, bindings, engagement stats.
//
// Fork-owned (Daybreak), not Sunrise. Per the boundary convention in
// `.context/framework/planning/framework-architecture.md` Appendix B (X6):
// every table here uses the `framework_` prefix via `@@map`, and its DDL lands
// only in `framework_`-named migrations touching only `framework_*` tables.
// Prisma model names stay clean/unprefixed (e.g. `model Module { @@map("framework_module") }`).
//
// First table (f-module-core t-1). See `.context/framework/planning/f-module-core.md`
// and spec §4.1.

// A registered module's operator-controlled row. The code half (identity, config
// schema, capabilities…) lives in a `ModuleDefinition` registered in code; this row
// holds only what an operator controls. Registration syncs code → row by slug at
// boot (`syncRegisteredModules()`), which writes code-owned data on create and only
// re-marks `isRegistered` on update — operator columns are never clobbered.
//
// `status`/`audience` are free-form `String`, not Prisma enums (convention X1: an
// enum makes every new value a migration and complicates fork merges). Effective
// availability is COMPUTED, never stored (`isModuleLive()` — status × flag × window,
// f-module-core t-2); this row stores the inputs, not the verdict.
//
// Scope note: config *versioning* (`ModuleVersion`, A10 → f-module-config) is
// intentionally absent — added by the feature that owns it, so no unused columns land
// early. The *agent* binding pivot (`ModuleAgentBinding`, A6) and the *workflow*
// binding pivot (`ModuleWorkflowBinding`, §4.2) both land here in f-module-bindings
// (t-1 and t-3 respectively), below.
model Module {
  id              String    @id @default(cuid())
  slug            String    @unique // matches the registered ModuleDefinition.slug
  name            String // display name; defaults from code, operator-overridable
  status          String    @default("draft") // draft | active | scheduled | retired (free-form, X1)
  featureFlagName String? // optional binding to a FeatureFlag (one on/off switch)
  availableFrom   DateTime? // limited-time window start (null = open-ended)
  availableUntil  DateTime? // limited-time window end (null = open-ended)
  audience        String    @default("all") // all | invite | flag-gated (free-form, X1)
  config          Json      @default("{}") // operator values, validated by the module's configSchema (f-module-config)
  isRegistered    Boolean   @default(true) // false = code removed but row retained for audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agentBindings      ModuleAgentBinding[]
  workflowBindings   ModuleWorkflowBinding[]
  knowledgeDocuments ModuleKnowledgeDocument[]
  knowledgeTags      ModuleKnowledgeTag[]

  @@index([status])
  @@map("framework_module")
}

// A module's durable *knowledge scope* (spec §4.2, "no new mechanism at all"). A
// module OWNS a set of knowledge documents/tags; every agent bound to the module
// inherits search access to that set. Two thin pivots mirror the core's own
// per-agent grant pivots (`AiAgentKnowledgeDocument` / `AiAgentKnowledgeTag`).
//
// The scope is NOT materialised onto agents. Enforcement stays the core
// `resolveAgentDocumentAccess` resolver, which unions a generic access-contributor's
// output into a restricted agent's document set (`registerAgentAccessContributor`,
// a core seam). The framework registers `resolveModuleKnowledgeForAgent`, which
// computes an agent's module-derived docs/tags LIVE from `ModuleAgentBinding` ⋈ these
// rows — so a bound agent inherits the scope with no copy, an unbound agent loses it
// automatically, and direct operator grants on the same agent are never clobbered.
// A `full`-mode agent already searches everything, so the contributor is a no-op for
// it (the module scope never narrows access, only widens a restricted agent's).
//
// `moduleId` is a Prisma relation to `Module` (both framework-owned, `onDelete:
// Cascade`). `documentId` / `tagId` are PLAIN scalar FKs to the core
// `ai_knowledge_document` / `knowledge_tag` tables (NO Prisma `@relation`, so a fork
// table never adds a reverse field to a Sunrise-owned model — the X6 boundary); their
// `ON DELETE CASCADE` is hand-written in the migration (the f-slots `SlotValue.userId`
// pattern), so deleting a document/tag drops its module grants. The admin actor is
// recorded via `logAdminAction`, not a column (as t-1 did — no runtime use for it).
model ModuleKnowledgeDocument {
  id         String   @id @default(cuid())
  moduleId   String
  documentId String // FK to AiKnowledgeDocument.id — no @relation; ON DELETE CASCADE hand-written in the migration
  createdAt  DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, documentId])
  @@index([documentId])
  @@map("framework_module_knowledge_document")
}

model ModuleKnowledgeTag {
  id        String   @id @default(cuid())
  moduleId  String
  tagId     String // FK to KnowledgeTag.id — no @relation; ON DELETE CASCADE hand-written in the migration
  createdAt DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, tagId])
  @@index([tagId])
  @@map("framework_module_knowledge_tag")
}

// A binding of a module *lifecycle event* to a published `AiWorkflow` (spec §4.2):
// "when event X happens in this module, run workflow Y". A thin trigger row —
// analogous to `AiWorkflowTrigger` (a third-party event → workflow) and
// `AiWorkflowSchedule` (a cron tick → workflow), but the source is an internal
// module-lifecycle event (`module.entered`, `module.completed`, …). The dispatch
// (`runModuleWorkflowBindings`) reuses the existing execution machinery unchanged:
// create a PENDING `AiWorkflowExecution` pinned to the workflow's published version,
// then `drainEngine(...)` — no new engine, no new run path.
//
// `moduleId` is a Prisma relation to `Module` (both framework-owned) with
// `onDelete: Cascade`. `workflowId` and `createdBy` are PLAIN scalar FKs to core
// tables (NO Prisma `@relation`, so a fork table never adds a reverse field to the
// Sunrise-owned `AiWorkflow` / `User` models — the X6 boundary); their FKs are
// HAND-WRITTEN in the migration SQL (the f-slots `SlotValue.userId` pattern, B11):
// `workflowId → ai_workflow ON DELETE CASCADE` (delete the workflow, its bindings go)
// and `createdBy → "user" ON DELETE SET NULL` (retain the binding when its author is
// erased — the CLAUDE.md onDelete policy for retained config: nullable + SetNull,
// mirroring `AiWorkflowTrigger.creator`). So a dispatch that needs the workflow's
// definition loads it explicitly in the service, not via `include`.
//
// `eventType` is a free-form `String` (X1), matched against the event the source
// fires; role/event vocabularies are code, never a DB enum. `inputTemplate` is the
// operator's static input (the `AiWorkflowSchedule.inputTemplate` precedent), merged
// under the live event envelope at dispatch. `enabled` gates firing without deleting.
model ModuleWorkflowBinding {
  id            String   @id @default(cuid())
  moduleId      String
  eventType     String // the module-lifecycle event that fires this (free-form, X1)
  workflowId    String // FK to AiWorkflow.id — no @relation; ON DELETE CASCADE hand-written in the migration
  inputTemplate Json? // operator's static input, merged under the event envelope at dispatch
  enabled       Boolean  @default(true) // gate firing without deleting the binding
  createdBy     String? // FK to User.id — no @relation; ON DELETE SET NULL hand-written (retain on erasure)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, eventType, workflowId])
  @@index([moduleId])
  @@index([workflowId])
  @@map("framework_module_workflow")
}

// A binding of an ordinary `AiAgent` into a module *seat* (spec §4.2, decision A6).
// Agents are never owned by a module — they bind, with a `role` (one of the module's
// code-declared `agentRoles`) that names the seat. A universal agent is one bound
// into many modules; a module-specific agent is bound into one. Nothing on `AiAgent`
// changes (agent admin stays where it is).
//
// `moduleId` is a Prisma relation to `Module` (both framework-owned) with
// `onDelete: Cascade` — delete a module, its bindings go. `agentId` is a PLAIN scalar
// FK to core `AiAgent` (NO Prisma `@relation`, so a fork table never adds a reverse
// field to the Sunrise-owned `AiAgent` model — the X6 boundary); the
// `ON DELETE CASCADE` to `ai_agent` is HAND-WRITTEN in the migration SQL, the same
// pattern f-slots used for `SlotValue.userId` (B11). So reads that need the agent's
// display name stitch it in the service (`bindings/queries.ts`), not via `include`.
//
// `role` is a free-form `String` (X1), validated against the registered module's
// `agentRoles` at bind time, not by a DB enum. `isPrimary` marks the module's single
// lead seat (e.g. the chat companion); the bind service keeps at most one per module.
// `config` holds per-binding overrides (tone hints, etc.), opaque here.
model ModuleAgentBinding {
  id        String   @id @default(cuid())
  moduleId  String
  agentId   String // FK to AiAgent.id — no @relation; ON DELETE CASCADE hand-written in the migration
  role      String // one of the module's declared agentRoles (validated at bind time)
  isPrimary Boolean  @default(false) // the module's lead seat (e.g. chat companion); ≤ 1 per module
  config    Json? // per-binding overrides (tone hints, etc.), opaque to the framework
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, agentId, role])
  @@index([moduleId])
  @@index([agentId])
  @@map("framework_module_agent")
}
