// Framework — Modules domain: module config, bindings, engagement stats.
//
// Fork-owned (Daybreak), not Sunrise. Per the boundary convention in
// `.context/framework/planning/framework-architecture.md` Appendix B (X6):
// every table here uses the `framework_` prefix via `@@map`, and its DDL lands
// only in `framework_`-named migrations touching only `framework_*` tables.
// Prisma model names stay clean/unprefixed (e.g. `model Module { @@map("framework_module") }`).
//
// First table (f-module-core t-1). See `.context/framework/planning/f-module-core.md`
// and spec §4.1.

// A registered module's operator-controlled row. The code half (identity, config
// schema, capabilities…) lives in a `ModuleDefinition` registered in code; this row
// holds only what an operator controls. Registration syncs code → row by slug at
// boot (`syncRegisteredModules()`), which writes code-owned data on create and only
// re-marks `isRegistered` on update — operator columns are never clobbered.
//
// `status`/`audience` are free-form `String`, not Prisma enums (convention X1: an
// enum makes every new value a migration and complicates fork merges). Effective
// availability is COMPUTED, never stored (`isModuleLive()` — status × flag × window,
// f-module-core t-2); this row stores the inputs, not the verdict.
//
// Scope note: config *versioning* (`ModuleVersion`, A10 → f-module-config) and the
// *workflow* binding pivot (`ModuleWorkflowBinding`, A8 → f-module-bindings t-3) are
// intentionally absent — added by the features that own them, so no unused columns
// land early. The *agent* binding pivot (`ModuleAgentBinding`, A6) lands here in
// f-module-bindings t-1, below.
model Module {
  id              String    @id @default(cuid())
  slug            String    @unique // matches the registered ModuleDefinition.slug
  name            String // display name; defaults from code, operator-overridable
  status          String    @default("draft") // draft | active | scheduled | retired (free-form, X1)
  featureFlagName String? // optional binding to a FeatureFlag (one on/off switch)
  availableFrom   DateTime? // limited-time window start (null = open-ended)
  availableUntil  DateTime? // limited-time window end (null = open-ended)
  audience        String    @default("all") // all | invite | flag-gated (free-form, X1)
  config          Json      @default("{}") // operator values, validated by the module's configSchema (f-module-config)
  isRegistered    Boolean   @default(true) // false = code removed but row retained for audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agentBindings ModuleAgentBinding[]

  @@index([status])
  @@map("framework_module")
}

// A binding of an ordinary `AiAgent` into a module *seat* (spec §4.2, decision A6).
// Agents are never owned by a module — they bind, with a `role` (one of the module's
// code-declared `agentRoles`) that names the seat. A universal agent is one bound
// into many modules; a module-specific agent is bound into one. Nothing on `AiAgent`
// changes (agent admin stays where it is).
//
// `moduleId` is a Prisma relation to `Module` (both framework-owned) with
// `onDelete: Cascade` — delete a module, its bindings go. `agentId` is a PLAIN scalar
// FK to core `AiAgent` (NO Prisma `@relation`, so a fork table never adds a reverse
// field to the Sunrise-owned `AiAgent` model — the X6 boundary); the
// `ON DELETE CASCADE` to `ai_agent` is HAND-WRITTEN in the migration SQL, the same
// pattern f-slots used for `SlotValue.userId` (B11). So reads that need the agent's
// display name stitch it in the service (`bindings/queries.ts`), not via `include`.
//
// `role` is a free-form `String` (X1), validated against the registered module's
// `agentRoles` at bind time, not by a DB enum. `isPrimary` marks the module's single
// lead seat (e.g. the chat companion); the bind service keeps at most one per module.
// `config` holds per-binding overrides (tone hints, etc.), opaque here.
model ModuleAgentBinding {
  id        String   @id @default(cuid())
  moduleId  String
  agentId   String // FK to AiAgent.id — no @relation; ON DELETE CASCADE hand-written in the migration
  role      String // one of the module's declared agentRoles (validated at bind time)
  isPrimary Boolean  @default(false) // the module's lead seat (e.g. chat companion); ≤ 1 per module
  config    Json? // per-binding overrides (tone hints, etc.), opaque to the framework
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, agentId, role])
  @@index([moduleId])
  @@index([agentId])
  @@map("framework_module_agent")
}
