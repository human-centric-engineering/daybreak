// Framework — Facilitation domain: the map (graph + versions), per-user journey
// state, journey events, policies, and structure-change proposals.
//
// Fork-owned (Daybreak), not Sunrise. Per the boundary convention in
// `.context/framework/planning/framework-architecture.md` Appendix B (X6):
// every table here uses the `framework_` prefix via `@@map`, and its DDL lands
// only in `framework_`-named migrations touching only `framework_*` tables.
//
// Tables so far: the authored map — `FacilitationGraph` + immutable
// `FacilitationGraphVersion` snapshots (f-map t-2); per-user journey state —
// `UserJourney` + the `UserNodeState` projection + the insert-only `JourneyEvent`
// log (f-journey-state t-1). Policies / structure-change proposals arrive later.
// See `.context/framework/planning/f-map.md` / `f-journey-state.md` and spec §5.1–§5.2.

// A named facilitation map (spec §5.1, F1/F19). Authored config: the current
// draft (`draftDefinition`, draft-on-edit) plus a pointer to the live published
// snapshot. Mirrors `AiWorkflow`'s draft/published-version discipline. Multiple
// graphs per deployment are supported by design (F19 — a primary map and a
// supporter map are two rows). The `definition` shape is owned by
// `lib/framework/facilitation/map/schema.ts` and validated before every publish.
model FacilitationGraph {
  id                 String   @id @default(cuid())
  slug               String   @unique // stable identity; user journeys key on it
  name               String
  description        String?  @db.Text
  draftDefinition    Json? // in-progress edit; null when there is no draft
  publishedVersionId String? // FK to the currently live version
  createdBy          String? // user id — authored config (no User relation; see below)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  publishedVersion FacilitationGraphVersion?  @relation("FacilitationGraphPublishedVersion", fields: [publishedVersionId], references: [id])
  versions         FacilitationGraphVersion[] @relation("FacilitationGraphVersions")

  @@index([publishedVersionId])
  @@map("framework_facilitation_graph")
}

// Immutable snapshot of a map `definition` at publish time (F1/F2). Mirrors
// `AiWorkflowVersion`: new rows are inserted by `publishDraft` / `rollback`;
// existing rows are never mutated. `createdBy` is a bare `String` — it holds a
// user id OR `"agent:<slug>"` for an approved structure-change proposal (F17), so
// it is deliberately NOT a `User` relation (which would also mean editing Sunrise's
// `User` model). The map is authored config, not per-user data — no satellite FK
// here; personal data (journeys, events) arrives in `f-journey-state`.
model FacilitationGraphVersion {
  id            String   @id @default(cuid())
  graphId       String
  version       Int // monotonic per graph, starts at 1
  definition    Json // full map snapshot at publish time
  changeSummary String?  @db.Text // optional author-supplied label
  createdBy     String? // user id, or "agent:<slug>" (F17)
  createdAt     DateTime @default(now())

  graph        FacilitationGraph   @relation("FacilitationGraphVersions", fields: [graphId], references: [id], onDelete: Cascade)
  publishedFor FacilitationGraph[] @relation("FacilitationGraphPublishedVersion")

  @@unique([graphId, version])
  @@index([graphId])
  @@map("framework_facilitation_graph_version")
}

// ── Journey state (f-journey-state t-1, spec §5.2) ───────────────────────────
// Per-user runtime traversal of an authored map. Personal data on the satellite
// convention: `userId` is a PLAIN scalar FK to core `User` (no Prisma `@relation`
// — a fork table must not add a reverse field to the Sunrise-owned `User` model),
// with `ON DELETE CASCADE` hand-written in the migration SQL so `eraseUser()`
// erases it (spec §11; `.context/privacy/data-erasure.md`). The deterministic
// engine (`f-engine`, feature 11) is the SOLE writer of this state (F11); these
// models ship their shape + the erasure guarantee here — the writer arrives with
// the engine.

// One journey per user per graph PER CONTEXT (spec §5.2, F19). `graphSlug` is a
// plain string, NOT an FK to `FacilitationGraph` — state is interpreted against the
// live *published* version (F2), so republishing must never orphan a journey.
model UserJourney {
  id     String @id @default(cuid())
  userId String // FK to User.id — no @relation; ON DELETE CASCADE hand-written in the migration
  graphSlug String // the map being walked — plain string (F2), not an FK
  // Distinguishes parallel instances of the same map for one user (e.g. one user
  // supporting two different people through the same map — §8). NON-NULLABLE by
  // design (X3): Postgres treats NULLs as distinct in unique indexes, so a nullable
  // contextKey would let duplicate (userId, graphSlug) default journeys slip past
  // the @@unique below. "" = the default, context-free journey — the empty-string
  // sentinel is load-bearing.
  contextKey String   @default("")
  startedAt  DateTime @default(now())

  nodeStates UserNodeState[]
  events     JourneyEvent[]
  nudges     FrameworkJourneyNudge[]

  @@unique([userId, graphSlug, contextKey])
  @@map("framework_user_journey")
}

// Current standing per node — a materialised projection of the event log for cheap
// reads (F10; the same projection relationship `AiWorkflowExecution` has to its step
// events). `status` is free-form `String` (X1); the vocabulary lives in
// `lib/framework/facilitation/journey/vocabulary.ts`.
model UserNodeState {
  id             String @id @default(cuid())
  journeyId      String
  nodeKey        String
  status         String // unvisited | available | active | visited | completed
  timesCompleted Int    @default(0) // repeatable nodes count completions; status reflects the latest pass (F6)
  // Optional module-defined progress payload (e.g. % through a unit, mastery levels)
  // — shape owned by the node's module, opaque to the engine. Deeper attainment data
  // belongs in slots (F7).
  progress       Json?
  firstEnteredAt DateTime? // powers "firsts" / airport semantics
  lastActiveAt   DateTime?
  completedAt    DateTime? // most recent completion for repeatable nodes

  journey UserJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, nodeKey])
  @@map("framework_user_node_state")
}

// INSERT-ONLY — never updated, never deleted (except erasure). The full history and
// the source of truth `UserNodeState` projects (F10); also the synopsis agents' raw
// material, the stats feed (f-engagement, feature 08), and the admin timeline.
//
// The stream has TWO write-sources (spec §4.3 = §5.4 — one table): journey-traversal
// events (which set `journeyId` + `nodeKey`) and non-journey engagement events
// (`session.started`, module lifecycle — `journeyId` null). So it is keyed on
// `userId` (a PLAIN scalar FK, `ON DELETE CASCADE` hand-written in the migration) —
// the ONLY shape that reaches EVERY row from the user for erasure; a `journeyId`-only
// table would leave non-journey events with no FK path to the user (a GDPR hole).
// `journeyId` is an OPTIONAL Prisma relation (`SetNull`) for the journey-scoped
// events. `type` is free-form `String` (X1); f-engagement (08) extends the event
// vocabulary + the stats read side — not this schema.
model JourneyEvent {
  id         String   @id @default(cuid())
  userId     String // FK to User.id — no @relation; ON DELETE CASCADE hand-written in the migration (erasure path for EVERY event)
  journeyId  String? // set for journey-traversal events; null for non-journey engagement
  nodeKey    String?
  moduleSlug String?
  type       String // free-form event kind (X1) — e.g. node_entered, node_completed, session.started
  payload    Json?
  occurredAt DateTime @default(now())

  journey UserJourney? @relation(fields: [journeyId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt]) // erasure + per-user engagement reads
  @@index([journeyId, occurredAt]) // the journey timeline (§5.2)
  @@map("framework_journey_event")
}

// Facilitation agent binding (f-facilitation-agents t-1) — maps a facilitation SEAT
// (`role`) to an `AiAgent`, the second scope of the one binding mechanism (the first is
// `ModuleAgentBinding`). FLAT / parentless: unlike a module binding there is no
// facilitation entity to key on — the family is a deployment-wide role→agent map. `role`
// is validated in code against `FACILITATION_ROLES` (there is no per-instance `agentRoles`).
// `agentId` is a plain scalar FK (no Prisma `@relation`, so no reverse field on the
// Sunrise-owned `AiAgent`, X6); its `ON DELETE CASCADE` to `ai_agent` is hand-written in the
// migration (the `ModuleAgentBinding` pattern). No `userId` → not user data, no erasure path.
model FacilitationAgentBinding {
  id        String   @id @default(cuid())
  agentId   String // FK to AiAgent.id — no @relation; ON DELETE CASCADE hand-written in the migration
  role      String   @unique // one facilitation seat, one agent (a role IS the seat); validated against FACILITATION_ROLES
  config    Json? // per-binding overrides (tone hints, etc.), opaque to the framework
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@map("framework_facilitation_agent")
}

// Facilitation policy (f-policies t-1) — the typed governance-policy kinds (spec §5.5, F14):
// ONE table, a free-form `kind` discriminator (+ a raw-SQL CHECK in the migration — the §546
// free-string-plus-CHECK convention for a closed framework vocab, never a Prisma enum), and a
// per-kind Zod-validated `payload`. NOT a rules blob. Kinds resolve by loading the enabled rows
// of a kind and matching in code (admin-authored table, tens of rows — no JSON indexing). t-1
// ships `auto_approval`; `relevance_gating` (t-2), `guard_minimum` (t-3), `escalation` (t-4) add
// their kind to the CHECK + the `facilitationPolicySchema` discriminated union as they land.
// `createdBy` is a PLAIN scalar FK to core `User` (no Prisma `@relation`, X6; `ON DELETE SET NULL`
// hand-written — a policy is retained-config audit that outlives its author's erasure, like
// `ModuleVersion.createdBy`), so no erasure cascade/hook (unlike the user-data journey/slot tables).
model FacilitationPolicy {
  id        String   @id @default(cuid())
  kind      String // discriminator (auto_approval | …); CHECK-constrained in the migration, payload validated by facilitationPolicySchema
  enabled   Boolean  @default(true)
  payload   Json // per-kind config, validated by the kind's Zod schema
  createdBy String? // FK to User.id — no @relation; ON DELETE SET NULL hand-written in the migration (retain on erasure)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, enabled])
  @@map("framework_facilitation_policy")
}

// Structure-change proposal (f-emergence t-2, spec §5.5 F17) — the one narrow gate through which
// self-configuration (emergence) enters: a proposing agent (or an admin tool) writes a diff against
// the current published map, and it flows ONE pipeline — schema validation → engine invariant check
// → risk classification → approval → publish as a new version — so the deterministic spine is never
// written raw. v1 targets the MAP subject only (`subjectType` CHECK-constrained; module-config/policy
// subjects are an additive later scope). The full proposed map lives in `proposedDefinition` (map
// versioning is whole-snapshot). `status` is a CHECK-constrained free string (X1). `createdBy` is a
// PLAIN scalar (no `@relation`) that holds `"agent:<slug>"` for an agent author OR a user id — so it
// is deliberately not a `User` FK (X6), mirroring `FacilitationGraphVersion.createdBy`. `reviewedBy`
// (the approving admin) is a hand-FK to core `User`, `ON DELETE SET NULL` (retained audit).
model StructureChangeProposal {
  id                 String   @id @default(cuid())
  subjectType        String // 'map' (v1); CHECK-constrained. module_config/policy are additive later
  subjectId          String // the target map's graphSlug (v1)
  baseVersion        Int? // the published version the diff was made against (conflict detection); null if none published yet
  proposedDefinition Json // the full proposed map definition (whole-snapshot)
  status             String   @default("pending") // pending | approved | rejected | published — CHECK-constrained
  riskClass          String   @default("unclassified") // risk classification; the auto-approve taxonomy is deferred (§9.2)
  createdBy          String // "agent:<slug>" or a user id — no @relation (admits agent authorship, X6)
  reviewedBy         String? // approving/rejecting admin — FK to User.id; ON DELETE SET NULL hand-written
  rejectionReason    String?  @db.Text
  publishedVersionId String? // the FacilitationGraphVersion.id created on publish (set on approval, t-3)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([subjectType, subjectId, status], map: "framework_scp_subject_status_idx")
  @@index([status], map: "framework_scp_status_idx")
  @@map("framework_structure_change_proposal")
}

// Per-turn evaluation of a framework conversation (f-eval t-2..., spec §5.5 F14 — governance's
// post-hoc face). One row per scored ASSISTANT turn: the existing named-metric scorer
// (`scoreResponse`, which reuses the core eval judges) runs over facilitation/module conversation
// turns read from `AiMessage`, and its scores land here. A framework-owned table rather than the
// core `AiEvaluationLog` (which is mandatorily bound to a `userId`-owned `AiEvaluationSession` — the
// wrong shape for a surface/context-keyed framework batch). `messageId` is a PLAIN scalar FK to core
// `ai_message` (no Prisma `@relation`, X6); its `ON DELETE CASCADE` is hand-written, so an eval row
// is erased with its message (which cascades from the user) — GDPR-clean, no separate hook.
// `supervisorReport` holds the optional post-hoc supervisor verdict (t-2).
model FrameworkConversationEval {
  id               String   @id @default(cuid())
  conversationId   String // the AiConversation scored
  messageId        String   @unique // the assistant AiMessage turn — one eval per turn (re-scoring upserts)
  contextType      String // 'facilitation' | 'module' — the framework surface
  contextId        String? // role (facilitation) or module slug
  faithfulness     Float? // 0..1, or null when the metric doesn't apply / the judge failed
  groundedness     Float?
  relevance        Float?
  judgeReasoning   Json? // { faithfulness: { reasoning, evaluationSteps? }, groundedness: …, relevance: … }
  costUsd          Float    @default(0) // sum of the three judge calls
  supervisorReport Json? // optional post-hoc supervisor verdict (f-eval t-2)
  scoredAt         DateTime @default(now())

  @@index([conversationId])
  @@index([contextType, contextId])
  @@map("framework_conversation_eval")
}

// Per-node embedding of an authored facilitation map (f-overlays t-1, spec §5.4, F9 — advisory
// overlays). One row per node of a PUBLISHED map version: the node's composed text
// (`composeNodeText`) is embedded via the core embedder and the vector lands here, so guidance can
// suggest thematically-"related places" (t-2) — strictly ADVISORY, never an eligibility input (F9;
// enforced in `engine/availability.ts`/`graph-store.ts`). Keyed on `(graphSlug, nodeKey, version)`:
// map nodes are JSON inside `FacilitationGraphVersion.definition`, not rows, so there is no node FK;
// keying on the monotonic published `version` means republishing mints a new version and naturally
// invalidates stale embeddings (a query for the current version finds no rows until re-embedded — the
// advisory result degrades to empty, safe). Authored config (no `userId`) → NO erasure hook.
//
// `embedding` is pgvector's `vector(1536)` (Prisma-unmodelled `Unsupported`, like `AiMessageEmbedding`);
// its HNSW index (`idx_framework_node_embedding`, `vector_cosine_ops`) is hand-written in the migration
// SQL (Prisma can't emit `USING hnsw`) and probed via the framework drift bridge (`lib/framework/db-drift.ts`).
// The `embeddingModel`/`Provider`/`Dimension` provenance powers the search-time dimension drift-guard
// (t-2), mirroring `AiKnowledgeChunk`/`AiMessageEmbedding`.
model FrameworkNodeEmbedding {
  id                 String                      @id @default(cuid())
  graphSlug          String // the FacilitationGraph.slug — plain string (nodes/versions are JSON, F2), not an FK
  nodeKey            String // MapNode.key within the published version
  version            Int // the published FacilitationGraphVersion.version this embedding is for
  embedding          Unsupported("vector(1536)")
  embeddingModel     String? // provenance — the model that produced this vector
  embeddingProvider  String? // provenance — the providerType
  embeddingDimension Int? // provenance — powers the search-time dimension drift-guard (t-2)
  sourceText         String?                     @db.Text // the composed text that was embedded (debug/provenance)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@unique([graphSlug, nodeKey, version])
  @@index([graphSlug, version])
  @@map("framework_node_embedding")
}

// Proactive-guidance nudge throttle (f-overlays t-3b, spec §5.4, F13). One row per journey the sweep
// has emailed a "next step" nudge to, so a repeated sweep (a 60-second scheduler tick) does not
// re-nudge the same journey — the delivery service skips journeys nudged within a throttle window and
// upserts this row on each send. `nodeKey` records the step last nudged toward (audit/debug).
//
// `journeyId` is a real Prisma `@relation` to `UserJourney` (both framework-owned, so a reverse field
// is fine — unlike an FK to a Sunrise table, X6), `ON DELETE CASCADE`: the throttle row dies with its
// journey. `userId` is ALSO carried as a PLAIN scalar hand-FK to core `User`, `ON DELETE CASCADE`
// hand-written in the migration (no `@relation`, X6) — the direct GDPR erasure path (spec §11), matching
// the journey tables. `@@unique([journeyId])` keeps it to one throttle row per journey (upsert target).
model FrameworkJourneyNudge {
  id        String   @id @default(cuid())
  userId    String // FK to User.id — no @relation; ON DELETE CASCADE hand-written in the migration (erasure path)
  journeyId String   @unique // one throttle row per journey; the upsert key
  nodeKey   String // the next-step node last nudged toward (audit/debug)
  nudgedAt  DateTime @default(now())

  journey UserJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("framework_journey_nudge")
}
